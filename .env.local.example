# EmailJS credentials for the Contact form
# Get these from https://dashboard.emailjs.com/admin
#
# 1. Create a free account at emailjs.com
# 2. Add an "Email Service" (e.g. Gmail) -> copy the Service ID
# 3. Create an "Email Template" with {{name}}, {{email}}, {{message}} variables -> copy the Template ID
# 4. Go to Account > General -> copy the Public Key
#
# Copy this file to .env.local and fill in the values below.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
